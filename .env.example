# UPS API Credentials
# Obtain from https://developer.ups.com/
UPS_CLIENT_ID=your_ups_client_id_here
UPS_CLIENT_SECRET=your_ups_client_secret_here

# UPS Environment: sandbox | production
# Use "sandbox" during development (hits wwwcie.ups.com)
UPS_ENVIRONMENT=sandbox

# Request timeout in milliseconds (default: 10000)
UPS_TIMEOUT_MS=10000

# Seconds before token expiry to trigger a proactive refresh (default: 60)
# Prevents serving a token that expires mid-request
UPS_TOKEN_REFRESH_BUFFER_SECS=60

NODE_ENV=development
